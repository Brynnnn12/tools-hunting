# Environment variables for recon.sh
# Add your API keys and configuration here
  
# Chaos API Key for chaos-client
CHAOS_KEY=your_chaos_api_key_here
  

# Configuration variables (optional, will use defaults if not set)
# RATE_LIMIT=50                    # DNS query rate limit
# MODE=auto                        # Scan mode: auto/passive/full
# TOOL_VERSION=1.0                 # Tool version
# LOG_DIR=logs                     # Log directory name
# RESOURCE_DIR=$HOME/.config/recon # Directory for shared files (resolvers.txt, wordlist.txt)
# ALT_DNS_PATH=                    # Custom path to altdns binary (leave empty for auto-detection)

# Target directory for bug bounty targets
TARGETS_DIR=$HOME/bugbounty/targets

# Bug Bounty Tool Configuration
AUTHOR=Bryan
TOOL_VERSION=1.0
  
# Other environment variables can be added here
# EXAMPLE_VAR=example_value