# Recon Tool .gitignore

# Output directories (auto-generated scan results)
recon_*/

# Log files
*.log
logs/

# Environment variables (contains sensitive API keys)
.env
.env.local
.env.*.local

# Temporary files
*.tmp
*.temp
*~

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo
*~

# Compiled binaries (if any)
*.exe
*.out
*.bin

# Python cache
__pycache__/
*.py[cod]
*$py.class
*.so

# Go build artifacts
*.exe
*.exe~
*.dll
*.so
*.dylib
*.test
*.out

# Backup files
*.bak
*.backup
*.orig

# Package files
*.tar.gz
*.zip

# Node.js (if used for any tools)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# macOS
.AppleDouble
.LSOverride

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# Linux
*~

# Temporary directories
tmp/
temp/